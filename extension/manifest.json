{
  "manifest_version": 3,
  "name": "Open my files & apps",
  "version": "0.1.1",
  "description": "Open files, folders & URLs from one panel. Windows helper: native pickers + launch. List stored locally.",
  "permissions": ["storage", "nativeMessaging", "windows"],
  "action": {
    "default_title": "Open my files & apps",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
