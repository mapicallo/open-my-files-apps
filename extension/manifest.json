{
  "manifest_version": 3,
  "name": "Open my files & apps",
  "version": "0.1.9",
  "description": "Open files, folders & URLs from one panel. Optional Windows helper for native pickers; list stays local.",
  "homepage_url": "https://github.com/mapicallo/open-my-files-apps",
  "minimum_chrome_version": "109",
  "permissions": ["storage", "nativeMessaging", "windows"],
  "action": {
    "default_title": "Open my files & apps",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
